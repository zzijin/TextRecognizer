<Page x:Class="OcrClient.UI.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      d:DesignHeight="500" d:DesignWidth="600"
      Title="Settings"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="24">
            <StackPanel MaxWidth="520">
            <TextBlock Text="设置" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBlock Text="修改后点击保存，重启客户端生效" FontSize="13"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,16"/>

            <!-- Server -->
            <TextBlock Text="服务连接" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="服务地址" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding ViewModel.BaseUrl, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="启动最大尝试次数" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding ViewModel.StartupMaxAttempts, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="启动轮询间隔 (ms)" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding ViewModel.StartupPollIntervalMs, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="健康检查超时 (秒)" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding ViewModel.HealthTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="监控轮询间隔 (ms)" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding ViewModel.HealthMonitorIntervalMs, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="断开前最大失败次数" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding ViewModel.HealthMaxFailures, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="请求超时 (秒)" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding ViewModel.RequestTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- OCR Service -->
            <TextBlock Text="OCR 服务" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,10"/>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="服务目录路径" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding ViewModel.ServiceDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="2" Content="浏览" Width="56"
                        Command="{Binding ViewModel.BrowseServiceDirCommand}"
                        Margin="6,0,0,0" Padding="6,2"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="虚拟环境路径" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding ViewModel.VenvPath, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="服务脚本名" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding ViewModel.ServerScript, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="启动时杀掉已有服务" VerticalAlignment="Center"/>
                <CheckBox Grid.Column="1" VerticalAlignment="Center"
                          IsChecked="{Binding ViewModel.KillExistingOnStartup}"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="捕获 Python 输出日志" VerticalAlignment="Center"/>
                <CheckBox Grid.Column="1" VerticalAlignment="Center"
                          IsChecked="{Binding ViewModel.CapturePythonOutput}"/>
            </Grid>

            <!-- Environment check -->
            <TextBlock Text="环境检测" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,10"/>

            <StackPanel Margin="0,0,0,8">
                <ui:Button Appearance="Info"
                           Command="{Binding ViewModel.CheckEnvironmentCommand}"
                           Content="检测 OCR 环境"
                           Icon="{ui:SymbolIcon CheckmarkCircle24}"
                           HorizontalAlignment="Left"/>

                <ItemsControl ItemsSource="{Binding ViewModel.EnvCheckResults}" Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Top" FontSize="14">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOk}" Value="True">
                                                    <Setter Property="Text" Value="✓"/>
                                                    <Setter Property="Foreground" Value="Green"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsOk}" Value="False">
                                                    <Setter Property="Text" Value="✗"/>
                                                    <Setter Property="Foreground" Value="Red"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding Message}" FontSize="12"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="{Binding ViewModel.StatusMessage}"
                       FontSize="13" Margin="0,10,0,0"
                       Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>
                </StackPanel>

            <!-- Logging -->
            <TextBlock Text="日志" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,10"/>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="日志级别" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding ViewModel.LogLevelOptions}"
                          SelectedItem="{Binding ViewModel.LogLevel}"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="输出到控制台" VerticalAlignment="Center"/>
                <CheckBox Grid.Column="1" VerticalAlignment="Center"
                          IsChecked="{Binding ViewModel.EnableConsoleLog}"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="输出到文件" VerticalAlignment="Center"/>
                <CheckBox Grid.Column="1" VerticalAlignment="Center"
                          IsChecked="{Binding ViewModel.EnableFileLog}"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="日志目录" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding ViewModel.LogDirectory, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="轮转间隔" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding ViewModel.RollingIntervalOptions}"
                          SelectedItem="{Binding ViewModel.RollingInterval}"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="单文件最大 (KB)" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding ViewModel.RollingSizeKB, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <ui:Button Appearance="Primary"
                           Command="{Binding ViewModel.SaveSettingsCommand}"
                           Content="保存"
                           Icon="{ui:SymbolIcon Save24}"
                           Margin="0,0,12,0"/>
                <ui:Button Appearance="Secondary"
                           Command="{Binding ViewModel.ResetSettingsCommand}"
                           Content="恢复默认"
                           Icon="{ui:SymbolIcon ArrowReset24}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,16">
            <TextBlock Text="MIT License"
                       FontSize="11" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock FontSize="11"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Center">
                <Hyperlink NavigateUri="https://github.com/zzijin/TextRecognizer"
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           TextDecorations="Underline">
                    github.com/zzijin/TextRecognizer
                </Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Page>
